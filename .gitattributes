# 强制所有文本文件使用 LF 换行符
# 防止 Windows/Git Bash 提交时带 CRLF, 导致目标板上 #!/bin/sh\r 报 bad interpreter
* text=auto eol=lf

# 显式声明 Shell 脚本/服务文件为文本, 强制 LF
*.sh text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.socket text eol=lf
*.conf text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
