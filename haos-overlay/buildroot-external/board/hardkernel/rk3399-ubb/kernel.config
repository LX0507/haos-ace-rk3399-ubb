# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

CONFIG_THERMAL_GOV_BANG_BANG=y

CONFIG_KEYBOARD_GPIO=y
CONFIG_KEYBOARD_GPIO_POLLED=y

# Enable DW watchdog driver - RK3399 hardware watchdog
# Without this, BootROM/U-Boot starts the watchdog but kernel can't pet it
# causing the system to reboot after ~60 seconds
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_SYSFS=y
CONFIG_DW_WATCHDOG=y
# Make the kernel watchdog core pet the hardware watchdog INDEFINITELY
# (don't stop after the default 60s open_timeout).
# Build #17 fixed the driver but the system still rebooted because
# CONFIG_WATCHDOG_OPEN_TIMEOUT defaults to 60 seconds - after which
# the kernel stops petting the bootloader-started hardware watchdog
# (since no userspace daemon opens /dev/watchdog - systemd.watchdog=0).
# Setting it to 0 means KTIME_MAX = never stop petting.
CONFIG_WATCHDOG_OPEN_TIMEOUT=0

#
# pstore/ramoops - capture kernel logs before reboot
# After a watchdog reboot, logs from the previous boot are available
# at /sys/fs/pstore/ for post-mortem debugging
#
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_RAM=y
#
# Automatically generated file based on RK3399 UBTECH Board Bingo hardware specification
# Linux/arm64 6.12.0 Kernel Configuration
#
# ----------------------------------------------------------------------
# Core and Architecture - RK3399
# ----------------------------------------------------------------------
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_PGTABLE_LEVELS=4
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_NR_CPUS=8
CONFIG_HOTPLUG_CPU=y
CONFIG_SCHED_HRTICK=y
CONFIG_TICK_ONESHOT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
CONFIG_HZ_300=y
CONFIG_COMPAT=y
CONFIG_SWP_EMULATION=y
CONFIG_KALLSYMS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_AIO=y
CONFIG_CPU_BIG_LITTLE=y
CONFIG_SCHED_HMP=y

#
# Platform selection - Rockchip RK3399
#
CONFIG_ARCH_ROCKCHIP=y

#
# Boot options
#
CONFIG_ARM_PSCI_FW=y
CONFIG_OF=y
CONFIG_OF_FLATTREE=y
CONFIG_ZBOOT_ROM_TEXT=y
CONFIG_ZBOOT_ROM_BSS=y

#
# Processor Power Management
#
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_CPU_PM=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y
CONFIG_CPUFREQ_GOV_SCHEDUTIL=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y

# DDR3/LPDDR3 controller (DMC)
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_ARM_RK3399_DMC_DEVFREQ=y

#
# Clock, Reset, PHY
#
CONFIG_COMMON_CLK=y
CONFIG_CLK_ROCKCHIP=y
CONFIG_CLK_RK3399=y
CONFIG_RESET_CONTROLLER=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_ROCKCHIP_PCIE=y
CONFIG_PHY_ROCKCHIP_INNO_USB2_PHY=y
CONFIG_PHY_ROCKCHIP_TYPEC_PHY=y

#
# ----------------------------------------------------------------------
# Device Drivers
# ----------------------------------------------------------------------

#
# MFD - RK808 PMU
#
CONFIG_MFD_CORE=y
CONFIG_MFD_RK808=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_RK808=y

#
# PINCTRL & GPIO
#
CONFIG_PINCTRL=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_ROCKCHIP=y

#
# DMA Engine
#
CONFIG_DMA_ENGINE=y
CONFIG_ROCKCHIP_DMA=y

#
# I2C (for RK808 PMU)
#
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_I2C_ROCKCHIP=y

#
# Serial port (UART2 - debug console)
#
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

#
# MMC/eMMC
#
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDIO_UNIFIED_CLS=y

#
# I/O optimization
#
CONFIG_BLK_DEV_INITRD=y
CONFIG_BLK_MQ_PCI=y

#
# USB Support
#
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_ARCH_HAS_HCD=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_OF_PLATFORM=y
CONFIG_USB_HUB=y
CONFIG_USB_COMMON=y

#
# USB Storage
#
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

#
# PCI bus support
#
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_PCIE_DW=y
CONFIG_PCIE_ROCKCHIP=y
CONFIG_PCIE_ROCKCHIP_HOST=y

#
# Networking (RTL8211E PHY + Rockchip GMAC)
#
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y
CONFIG_MII=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_STMMAC_RK=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_PHYLIB=y
CONFIG_FIXED_PHY=y
CONFIG_REALTEK_PHY=y

#
# Wireless (BCM43455 Wi-Fi/BT)
#
CONFIG_WLAN=y
CONFIG_CFG80211=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_BRCM_FDC=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMUTIL=y

CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_BCM=y
CONFIG_BT_HCIUART_NOKIA=y

#
# Graphics support (RK3399 + HDMI)
#
# Build #22/#24: Fix HDMI no display
# Root cause: upstream kernel-arm64-rockchip.config only has CONFIG_ROCKCHIP_VOP2=y
# (for RK3568/RK3588), but RK3399 uses VOP v1 which is CONFIG_ROCKCHIP_VOP.
# Also, DRM_ROCKCHIP depends on ROCKCHIP_IOMMU (see Kconfig).
# VOP nodes need power domains (RK3399_PD_VOPB/RK3399_PD_VOPL) to probe.
#
# Override all DRM sub-drivers from =m (upstream) to =y for early boot
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_ROCKCHIP_IOMMU=y
CONFIG_ROCKCHIP_VOP=y
CONFIG_ROCKCHIP_VOP2=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_DRM_DW_HDMI=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_CONNECTOR=y
CONFIG_DRM_DISPLAY_DP_AUX_BUS=y
CONFIG_DRM_TTM=y
CONFIG_DRM_GEM_DMA_HELPER=y
CONFIG_DRM_GEM_SHMEM_HELPER=y
CONFIG_DRM_DW_HDMI_I2S_AUDIO=y
CONFIG_DRM_DW_HDMI_CEC=y
CONFIG_DRM_DW_MIPI_DSI=y
CONFIG_DRM_BRIDGE=y
CONFIG_DRM_BRIDGE_CONNECTOR=y
CONFIG_DRM_PANEL_BRIDGE=y

# Power domains - VOP nodes need power-domains to probe
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y
CONFIG_ROCKCHIP_PM_DOMAINS=y

#
# VPU/Video support (RK3399 VDEC)
#
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_ROCKCHIP_VDEC=m

#
# IR Receiver
#
CONFIG_RC_CORE=y
CONFIG_IR_GPIO_CIR=y

#
# ADC Keys
#
CONFIG_INPUT=y
CONFIG_KEYBOARD_ADC=y
