#!/bin/sh
# HAOS-CN: 配置 hassio_dns 使用国内 DNS，禁用 CloudFlare DoT fallback
#
# 修复记录:
#   Build #34: curl --unix-socket 调 supervisor API（缺 Authorization 头 → 401）
#   Build #36: 加 nmcli 等待 + 重试
#   Build #37: 加 NM dispatcher 双保险
#   Build #38: 改用 ha CLI（内部已含 SUPERVISOR_TOKEN），避免 host 端拿 token
#              增加 hassio_cli 容器 exec 兜底
#   Build #45: 关键根因修复 - 直接修改 hassio_dns 容器内 /etc/corefile 中的
#              Cloudflare DoT 硬编码 (1.1.1.1/1.0.0.1)，用 SIGHUP 让 coredns 重读
#              + flock 防止 nm-dispatcher 多进程并发 (解决 'Another job is running')

set -e

SUPERVISOR_SOCK="/var/run/supervisor.sock"
# Build #49 关键修复: 不再硬编码 192.168.1.1
# 不同家庭 IP 网段不同: 192.168.0.1 / 192.168.1.1 / 10.0.0.1 / 192.168.2.1 等
# Build #50 关键修复: 路由器 DNS (默认网关) 实测**不一定可达**
#   - Build #48 日志显示 192.168.1.1:53 经常 i/o timeout (路由器 DNS 代理未响应)
#   - 单一路由器上游 → supervisor 永久 'No Supervisor connectivity'
# 改为「公共 DNS (119.29.29.29/223.5.5.5/8.8.8.8) + 路由器网关」多上游列表,
# 由 CoreDNS 健康检测自动故障转移: 路由器可用走路由器, 不可用走公共 DNS。
DNS_SERVERS=""  # 运行时由 init_dns_servers() 填充 (默认网关 IP, 仅作 ha dns info 标记)
# Corefile 上游 DNS 列表 (dns:// 前缀, 空格分隔) - 多上游故障转移
COREFILE_UPSTREAM_DNS=""  # 运行时由 init_dns_servers() 填充
# 空格分隔的 IP 上游列表 (用于 ha dns options / coredns.json)
UPSTREAM_LIST=""
DNS_COREDNS_JSON="/mnt/data/supervisor/dns/coredns.json"
# flock 锁: 防止 nm-dispatcher 多个进程同时执行配置逻辑
LOCK_FILE="/var/run/hassos-dns-cn-init.lock"

log() {
    echo "[hassos-dns-cn-init] $1"
    logger -t hassos-dns-cn-init "$1" 2>/dev/null || true
}

# 自动检测默认网关 IP (适配任意家庭网段)
# 优先级:
#   1. ip route 拿 default via X.X.X.X
#   2. nmcli 拿 end0 的 IP4.GATEWAY
#   3. nmcli 拿 end0 的 IP4.DNS (DHCP 给的 DNS, 通常 = 路由器 IP)
#   4. 兜底: 192.168.1.1 (最常见的家庭网段)
get_default_gateway() {
    local gw=""
    # 方法 1: ip route
    if command -v ip >/dev/null 2>&1; then
        gw=$(ip -4 route show default 2>/dev/null | awk '/^default/ {for(i=1;i<=NF;i++) if ($i=="via") {print $(i+1); exit}}' | head -1)
    fi
    # 方法 2: nmcli 拿 IP4.GATEWAY
    if [ -z "$gw" ] && command -v nmcli >/dev/null 2>&1; then
        gw=$(nmcli -t -f IP4.GATEWAY device show end0 2>/dev/null | head -1)
    fi
    # 方法 3: nmcli 拿 IP4.DNS (DHCP 给的 DNS, 通常 = 路由器 IP)
    if [ -z "$gw" ] && command -v nmcli >/dev/null 2>&1; then
        gw=$(nmcli -t -f IP4.DNS device show end0 2>/dev/null | head -1 | cut -d: -f1)
    fi
    # 方法 4: 兜底
    if [ -z "$gw" ]; then
        gw="192.168.1.1"
        log "WARNING: 无法自动检测默认网关, 使用兜底 192.168.1.1 (如果不对, 请手动设置)"
    fi
    echo "$gw"
}

# 公共 DNS 上游 (国内可达, 按优先级排列)
#   119.29.29.29  DNSPod / 腾讯 (国内普遍可达)
#   223.5.5.5     AliDNS / 阿里   (国内普遍可达)
#   8.8.8.8       Google (兜底, 国内通常被阻断, 仅作最后尝试)
# Build #50 关键: 不再只用默认网关 (路由器) 作唯一上游。本环境实测路由器 DNS
# (192.168.1.1:53) 经常 i/o timeout, 单一路由器上游会导致 supervisor 永久
# 'No Supervisor connectivity'。改为「公共 DNS + 路由器网关」多上游列表,
# CoreDNS 自动健康检测并故障转移。
PUBLIC_DNS_LIST="119.29.29.29 223.5.5.5 8.8.8.8"

# 生成 ha dns options / coredns.json 用的上游列表 (空格分隔 IP)
build_upstream_list() {
    local gw="$1"
    echo "$PUBLIC_DNS_LIST $gw"
}

# 生成 CoreDNS forward 用的上游列表 (dns:// 前缀, 空格分隔)
build_upstream_fmt() {
    local gw="$1"
    local out=""
    for s in $PUBLIC_DNS_LIST $gw; do
        out="$out dns://$s"
    done
    echo "${out# }"
}

# 初始化 DNS_SERVERS / UPSTREAM_LIST / COREFILE_UPSTREAM_DNS (运行时检测)
init_dns_servers() {
    local gw=$(get_default_gateway)
    DNS_SERVERS="$gw"
    UPSTREAM_LIST=$(build_upstream_list "$gw")
    COREFILE_UPSTREAM_DNS=$(build_upstream_fmt "$gw")
    log "检测到默认网关: $gw (将作为 DNS 标记)"
    log "Corefile 上游故障转移列表: $COREFILE_UPSTREAM_DNS"
}

# 配置 host DNS (systemd-resolved + NetworkManager)
# 关键：hassio_dns 的 locals 会从 host DNS 读取；host DNS 快则容器 DNS 也快
configure_host_dns() {
    log "配置 host DNS ..."
    # Build #50 关键修复: 不再把 host DNS 强行指向路由器 (可能 i/o timeout)。
    # 改为指向 hassio_dns (172.30.32.3); 实际解析由 hassio_dns 的 Corefile 多上游
    # 故障转移处理 (路由器不可用时自动转公共 DNS)。与 stock HA OS 行为一致, 也避免
    # dockerd resolver 直接查询已死路由器导致 i/o timeout。
    local dns_servers="172.30.32.3"

    # 方法1: 使用 resolvectl 设置 per-interface DNS（立即生效）
    if command -v resolvectl >/dev/null 2>&1; then
        if resolvectl dns end0 $dns_servers 2>/dev/null; then
            log "resolvectl 设置 end0 DNS 成功"
        else
            log "WARNING: resolvectl 设置 end0 DNS 失败"
        fi
    fi

    # 方法2: 使用 nmcli 修改当前连接（持久化）
    # 关键修复 (Build #43): 之前的版本立即查询 "connection show --active"，
    # 但当 service 早于 NM 激活 end0 时返回空 → 修复失败。
    # 现在重试最多 10 次 × 2s（共 20s），覆盖 NM 异步激活的窗口。
    if command -v nmcli >/dev/null 2>&1; then
        local conn_name=""
        local attempt=0
        local max_attempts=10
        while [ $attempt -lt $max_attempts ]; do
            conn_name=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | grep ':end0$' | cut -d: -f1 | head -1)
            if [ -n "$conn_name" ]; then
                break
            fi
            attempt=$((attempt + 1))
            log "等待 end0 活动连接就绪 (尝试 $attempt/$max_attempts) ..."
            sleep 2
        done

        if [ -n "$conn_name" ]; then
            if nmcli connection modify "$conn_name" ipv4.dns "$dns_servers" ipv4.ignore-auto-dns yes 2>/dev/null; then
                log "nmcli 修改连接 $conn_name IPv4 DNS 成功"
            else
                log "WARNING: nmcli 修改连接 $conn_name IPv4 DNS 失败"
            fi
            if nmcli connection modify "$conn_name" ipv6.ignore-auto-dns yes 2>/dev/null; then
                log "nmcli 禁用 $conn_name IPv6 auto DNS 成功"
            else
                log "WARNING: nmcli 禁用 $conn_name IPv6 auto DNS 失败"
            fi
        else
            log "WARNING: ${max_attempts} 次重试后仍未找到 end0 活动连接（NM 可能未激活）"
        fi
    fi
}

# 检查 supervisor.sock 是否就绪
wait_for_supervisor_sock() {
    log "等待 supervisor.sock 就绪 ..."
    for i in $(seq 1 180); do
        [ -S "$SUPERVISOR_SOCK" ] && break
        sleep 1
    done
    if [ ! -S "$SUPERVISOR_SOCK" ]; then
        log "ERROR: supervisor.sock 180s 内未就绪"
        return 1
    fi
    return 0
}

# 检查 hassio_cli 容器是否启动（ha CLI 入口）
wait_for_hassio_cli() {
    log "等待 hassio_cli 容器就绪 ..."
    for i in $(seq 1 180); do
        if command -v docker >/dev/null 2>&1; then
            if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
                return 0
            fi
        fi
        sleep 1
    done
    log "WARNING: hassio_cli 容器 180s 内未就绪"
    return 1
}

# 等待 hassio_dns 容器进入"健康"状态
# 关键修复 (Build #43): 避免在 hassio_dns 起来前触发 supervisor healthcheck，
# 否则 dockerd [resolver] 会发 connection refused → supervisor 立即判 No connectivity
# 关键修复 (Build #46): 之前检测 host 127.0.0.1:53，但 hassio_dns 容器**不监听 host
# 127.0.0.1:53**（只在 hassio bridge 172.30.32.3:53 监听）。改为在容器内
# 用 docker exec 检测 coredns 进程和 Corefile 状态。
wait_for_hassio_dns_healthy() {
    log "等待 hassio_dns 容器健康 ..."
    local attempt=0
    local max_attempts=60
    while [ $attempt -lt $max_attempts ]; do
        if command -v docker >/dev/null 2>&1; then
            if docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
                # 关键 (Build #46): 在容器内检查 coredns 进程是否运行
                if docker exec hassio_dns sh -c 'pidof coredns >/dev/null 2>&1' 2>/dev/null; then
                    log "hassio_dns 健康（coredns 进程运行中）"
                    return 0
                fi
            fi
        fi
        attempt=$((attempt + 1))
        if [ $((attempt % 5)) -eq 0 ]; then
            log "hassio_dns 尚未健康 (尝试 $attempt/$max_attempts) ..."
        fi
        sleep 1
    done
    log "WARNING: hassio_dns ${max_attempts}s 内未健康"
    return 1
}

# 检查 end0 是否已获取 IPv4
wait_for_ipv4() {
    log "等待 end0 获取 IPv4 ..."
    for i in $(seq 1 180); do
        if command -v nmcli >/dev/null 2>&1; then
            if nmcli -g IP4.ADDRESS device show end0 2>/dev/null | grep -Eq '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'; then
                log "end0 IPv4 已获取"
                return 0
            fi
        else
            if ip -4 addr show end0 2>/dev/null | grep -Eq 'inet [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/'; then
                log "end0 IPv4 已获取 (ip command)"
                return 0
            fi
        fi
        sleep 1
    done
    log "WARNING: 180s 内未检测到 end0 IPv4，继续尝试配置 ..."
    return 1
}

# 幂等检查：通过 hassio_cli 容器调 ha dns info
# Build #49: 改为检查运行时检测的 DNS_SERVERS (默认网关 IP)
is_already_configured() {
    if command -v docker >/dev/null 2>&1 && [ -n "$DNS_SERVERS" ]; then
        INFO=$(docker exec hassio_cli ha dns info 2>/dev/null || true)
        if echo "$INFO" | grep -qF "$DNS_SERVERS"; then
            log "DNS 已配置为 ${DNS_SERVERS} (hassio_cli ha dns info)"
            return 0
        fi
    fi
    return 1
}

# 检查 hassio_dns 容器内 /etc/corefile 是否已修复 (Cloudflare DoT 已被替换)
# 关键修复 (Build #45): 之前只检查 coredns.json 是不够的，因为 Cloudflare DoT
# 硬编码在 hassio_dns 容器内的 tempio 模板 /usr/share/tempio/corefile 中，
# coredns.json 是动态数据（不含 tls://1.1.1.1）。
is_corefile_already_fixed() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
        return 1
    fi
    # 检查 hassio_dns 容器内的 /etc/corefile 是否还包含 Cloudflare DoT
    if docker exec hassio_dns sh -c 'grep -qE "tls://1\.1\.1\.1|tls://1\.0\.0\.1|tls://cloudflare-dns\.com" /etc/corefile' 2>/dev/null; then
        return 1  # 仍有 Cloudflare DoT，需要修复
    fi
    # 检查是否仍走 dockerd internal (127.0.0.11) 死循环
    if docker exec hassio_dns sh -c 'grep -qE "forward \. dns://127\.0\.0\.11" /etc/corefile' 2>/dev/null; then
        return 1  # 仍走 dockerd internal，需要修复
    fi
    return 0  # 已修复
}

# 修复 hassio_dns 容器内 /etc/corefile 的 Cloudflare DoT + .:53 forward 死循环
# Build #50 关键修复: 用「公共 DNS + 路由器网关」多上游故障转移列表替换,
# 不再只用单一路由器 IP (实测 192.168.1.1:53 经常 i/o timeout)。
# CoreDNS forward 支持多个上游, 自动健康检测并故障转移。
fix_coredns_dot_fallback() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
        log "hassio_dns 容器未运行，跳过 Corefile 修复"
        return 1
    fi

    # 用运行时检测的故障转移上游列表
    local UPSTREAM_FMT="$COREFILE_UPSTREAM_DNS"
    if [ -z "$UPSTREAM_FMT" ]; then
        UPSTREAM_FMT=$(build_upstream_fmt "$(get_default_gateway)")
        COREFILE_UPSTREAM_DNS="$UPSTREAM_FMT"
    fi
    log "Corefile 上游故障转移列表: $UPSTREAM_FMT"

    # 备份当前 Corefile（容器内）
    docker exec hassio_dns sh -c 'cp -f /etc/corefile /etc/corefile.bak 2>/dev/null || true' || true

    # 是否需要修复 (检测 Cloudflare DoT 或 .:53 forward 走 dockerd internal)
    local needs_fix=0
    if docker exec hassio_dns sh -c 'grep -qE "tls://1\.1\.1\.1|tls://1\.0\.0\.1|tls://cloudflare-dns\.com" /etc/corefile' 2>/dev/null; then
        log "检测到 hassio_dns 容器 /etc/corefile 含 Cloudflare DoT"
        needs_fix=1
    fi
    if docker exec hassio_dns sh -c 'grep -qE "forward \. dns://127\.0\.0\.11" /etc/corefile' 2>/dev/null; then
        log "检测到 hassio_dns 容器 /etc/corefile .:53 forward 走 dockerd internal (死循环源)"
        needs_fix=1
    fi

    if [ "$needs_fix" -eq 0 ]; then
        log "hassio_dns 容器 /etc/corefile 已修复 (无 Cloudflare DoT, 上游已是外部 DNS 列表)"
        return 0
    fi

    log "开始修复 hassio_dns 容器 /etc/corefile ..."

    # 关键修复: 把 Corefile 中所有 'forward .' 行 (.:53 和 .:5553 两个 server block)
    # 统一替换为多上游故障转移列表。用整行替换避免重复 (旧逻辑把 tls://1.1.1.1 和
    # tls://1.0.0.1 都替换成同一 IP, 导致 'forward . dns://X dns://X' 重复)。
    if docker exec hassio_dns sh -c "sed -i -E 's|^( *)forward \. .*|\1forward . ${UPSTREAM_FMT}|' /etc/corefile" 2>/dev/null; then
        log "已替换 Corefile 所有 forward 为多上游故障转移列表: ${UPSTREAM_FMT}"
    else
        log "WARNING: 替换 Corefile forward 失败"
    fi

    # 验证修复结果
    docker exec hassio_dns sh -c 'cat /etc/corefile' 2>/dev/null | grep -E "forward \." | head -5 | while read line; do
        log "  Corefile forward: $line"
    done

    # 关键: 用 SIGHUP 让 CoreDNS 重新读取 Corefile（不重启容器）
    # 这样 supervisor 不会重新生成 Corefile，修复持续生效。
    if docker exec hassio_dns sh -c 'pkill -HUP coredns 2>/dev/null; sleep 1' 2>/dev/null; then
        log "已 SIGHUP hassio_dns 容器内 coredns 让其重读 Corefile"
        return 0
    fi
    # 兜底: 用 s6-svc 重启服务 (不重启容器)
    if docker exec hassio_dns sh -c 's6-svc -h /run/service/coredns 2>/dev/null; sleep 1' 2>/dev/null; then
        log "已通过 s6-svc -h 重启 hassio_dns 容器内 coredns"
        return 0
    fi
    log "WARNING: 通知 CoreDNS 重读 Corefile 失败"
    return 1
}

# 方案 A：通过 ha CLI 配置 DNS（推荐，CLI 内部已处理 token）
configure_via_ha_cli() {
    log "通过 'ha dns' CLI 配置国内 DNS ..."
    if ! command -v docker >/dev/null 2>&1; then
        log "docker 命令不可用"
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
        log "hassio_cli 容器未运行"
        return 1
    fi

    # 先禁用 fallback
    if docker exec hassio_cli ha dns options --fallback=false 2>&1; then
        log "fallback=false 设置成功"
    else
        log "WARNING: 禁用 fallback 失败"
    fi

    # 设置多上游 DNS servers (公共 DNS + 路由器网关, CoreDNS 故障转移)
    local opts=""
    for s in $UPSTREAM_LIST; do
        opts="$opts --servers dns://$s"
    done
    if docker exec hassio_cli ha dns options $opts 2>&1; then
        log "国内 DNS servers 设置成功"
    else
        log "WARNING: 设置 DNS servers 失败"
        return 1
    fi

    # 关键：先配置 host DNS，再修复 Corefile
    # 这样 hassio_dns 容器内 /etc/corefile 的 .:53 forward 已有正确的 fallback 路径
    configure_host_dns

    # 关键修复 (Build #45): 修复 hassio_dns 容器内 /etc/corefile 的 Cloudflare DoT
    # 这是 Build #44 失败的核心根因。coredns.json 中不含 tls://1.1.1.1，
    # Cloudflare DoT 硬编码在 hassio_dns 容器内 tempio 模板 /usr/share/tempio/corefile。
    # 必须直接 docker exec 修改 /etc/corefile 并 SIGHUP coredns (不重启容器)。
    fix_coredns_dot_fallback || log "WARNING: Corefile DoT 修复失败（hassio_dns 容器问题）"

    # 关键修复 (Build #43): 等 hassio_dns 完全健康（CoreDNS listening）后再 healthcheck
    # 否则 dockerd [resolver] 会发 checkonline → 127.0.0.1:53 connection refused
    # （hassio_dns 还在启动中）→ supervisor 立即判 No connectivity
    wait_for_hassio_dns_healthy || true

    # Build #50: 不再强行覆盖 supervisor 容器 /etc/resolv.conf。
    # supervisor 默认 resolv.conf 指向 hassio_dns (172.30.32.3), 而 hassio_dns 的
    # Corefile 已被我们改成多上游故障转移列表, supervisor 走 hassio_dns 即可正确
    # 解析。之前的 nohup 后台 watch 进程既造成进程泄漏, 又会在路由器 DNS 不可用时
    # 把 supervisor 重新指向已死的路由器, 现已移除。

    # 关键修复 (Build #44): 重启 assismgr 让它重新读 /etc/resolv.conf
    # assismgr 启动时 (T=46s) /etc/resolv.conf 仍是 dhcp 路由器 DNS，
    # 即使后来 supervisor 改了 resolv.conf (T=115s)，assismgr 进程内的 DNS
    # 解析器已缓存旧的 DNS 列表，导致其 ping 检查一直 fail
    # 重启 assismgr 后它会读新的 resolv.conf → 用 hassio_dns 解析域名
    # 注意 (Build #45): 不重启 dockerd（避免重启 supervisor 容器导致 hassio_dns
    # 重新生成 Corefile 覆盖我们的修复）
    if command -v systemctl >/dev/null 2>&1; then
        log "重启 assismgr 服务让其重读 /etc/resolv.conf ..."
        systemctl restart assismgr 2>&1 | head -3 || log "WARNING: systemctl restart assismgr 失败"
    fi

    # 关键：触发 supervisor 重新检测网络 + 拉 HA Core 镜像
    # supervisor 启动时 DNS 未修好，被标记 'No Supervisor connectivity'，
    # 永远不会下载 ghcr.io 上的 homeassistant 镜像 (8123 永远是 landingpage)
    log "触发 supervisor 重新检测网络 (ha resolution healthcheck + ha supervisor reload) ..."
    docker exec hassio_cli ha resolution healthcheck 2>&1 || log "WARNING: healthcheck 失败"
    docker exec hassio_cli ha supervisor reload 2>&1 || log "WARNING: supervisor reload 失败"
    sleep 3
    # 再触发一次 healthcheck
    docker exec hassio_cli ha resolution healthcheck 2>&1 || log "WARNING: 第二次 healthcheck 失败"
    return 0
}

# 方案 B：通过 hassio_cli 容器 curl supervisor API（带 token）
configure_via_hassio_cli_curl() {
    log "通过 hassio_cli 容器 curl supervisor API ..."
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
        return 1
    fi

    # 在 hassio_cli 容器内执行 curl，自动获取 SUPERVISOR_TOKEN 环境变量
    # Build #50: 用多上游列表 (公共 DNS + 路由器网关)
    local servers_json=""
    for s in $UPSTREAM_LIST; do
        [ -n "$servers_json" ] && servers_json="$servers_json,"
        servers_json="${servers_json}\"dns://$s\""
    done
    local body="{\"servers\":[$servers_json],\"fallback\":false}"
    if docker exec -e BODY="$body" hassio_cli sh -c 'curl -fsS -m 30 -X POST -H "Authorization: Bearer $SUPERVISOR_TOKEN" -H "Content-Type: application/json" -d "$BODY" http://supervisor/dns/options' 2>&1; then
        log "Supervisor API 配置成功"
        return 0
    fi
    return 1
}

# 方案 C：直接修改 coredns.json + 写信号文件通知 supervisor
# Build #49: 用运行时检测的 DNS_SERVERS (路由器 IP)
configure_via_coredns_json() {
    log "兜底方案：直接修改 $DNS_COREDNS_JSON ..."
    if [ ! -d "$(dirname "$DNS_COREDNS_JSON")" ]; then
        mkdir -p "$(dirname "$DNS_COREDNS_JSON")"
    fi

    if [ -z "$UPSTREAM_LIST" ]; then
        UPSTREAM_LIST=$(build_upstream_list "$(get_default_gateway)")
    fi
    local srv_json=""
    for s in $UPSTREAM_LIST; do
        [ -n "$srv_json" ] && srv_json="$srv_json,"
        srv_json="${srv_json}\"dns://$s\""
    done

    if [ -f "$DNS_COREDNS_JSON" ] && command -v jq >/dev/null 2>&1; then
        # 保留其他字段，仅修改 servers 和 fallback
        jq --argjson srv "[$srv_json]" '.servers = $srv | .fallback = false' "$DNS_COREDNS_JSON" > "${DNS_COREDNS_JSON}.tmp" \
            && mv "${DNS_COREDNS_JSON}.tmp" "$DNS_COREDNS_JSON"
    else
        printf '%s\n' "{\"servers\":[$srv_json],\"fallback\":false,\"version\":\"2026.07.11\"}" > "$DNS_COREDNS_JSON"
    fi

    log "coredns.json 已更新 (servers: ${DNS_SERVERS})"
    return 0
}

# 主流程
main() {
    log "启动 (hassos-dns-cn-init)"

    # dispatcher 调用时带 interface 参数
    if [ -n "$1" ] && [ "$1" != "end0" ] && [ "$1" != "--force" ]; then
        log "非 end0 接口 ($1)，跳过"
        exit 0
    fi

    # 关键修复 (Build #49): 运行时检测默认网关 (适配任意家庭网段)
    # 必须早于任何 DNS 配置调用, 让 DNS_SERVERS 和 COREFILE_UPSTREAM_DNS 有正确值
    init_dns_servers

    # 关键修复 (Build #45): 用 flock 防止 nm-dispatcher 多个进程并发执行
    # Build #44 失败的关键原因之一: NM 重命名 end0 → "Supervisor end0" 时
    # 会触发 2 次 dispatcher 事件 (up + down)，导致 2 个 nm-dispatcher 进程
    # 同时调用 ha dns restart，第二个进程拿到 JobGroupExecutionLimitExceeded。
    # flock -n 16: 最多等 16s 拿锁，拿不到就立即跳过。
    if command -v flock >/dev/null 2>&1; then
        exec 9>"$LOCK_FILE"
        if ! flock -w 16 9; then
            log "另一个 hassos-dns-cn-init 实例正在执行，跳过（避免并发）"
            exit 0
        fi
    fi

    # 先配置 host DNS（无需等待 supervisor），让系统 / dockerd 尽早使用国内 DNS
    configure_host_dns

    wait_for_supervisor_sock || true
    wait_for_ipv4 || true
    wait_for_hassio_cli || true

    if is_already_configured && is_corefile_already_fixed; then
        log "国内 DNS 已配置，hassio_dns 容器 /etc/corefile 也已修复，跳过"
        exit 0
    fi

    # 方案 A: ha CLI
    if configure_via_ha_cli; then
        log "完成 (via 'ha dns' CLI)"
        # 验证最终状态
        sleep 2
        if command -v docker >/dev/null 2>&1; then
            docker exec hassio_cli ha dns info 2>&1 | head -10 | while read line; do
                log "  ha dns info: $line"
            done
        fi
        exit 0
    fi

    # 方案 B: hassio_cli curl
    if configure_via_hassio_cli_curl; then
        log "完成 (via hassio_cli curl)"
        exit 0
    fi

    # 方案 C: coredns.json 兜底
    log "WARNING: 所有 API 方案失败，兜底写 coredns.json"
    configure_via_coredns_json
    log "完成 (via coredns.json fallback)"
    log "用户可手动执行: ha dns options --fallback=false --servers dns://${DNS_SERVERS}"
}

main "$@"
