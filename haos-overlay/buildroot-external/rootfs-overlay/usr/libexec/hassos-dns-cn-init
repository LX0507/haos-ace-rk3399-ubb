#!/bin/sh
# HAOS-CN: 配置 hassio_dns 使用国内 DNS，禁用 CloudFlare DoT fallback
#
# 修复记录:
#   Build #34: curl --unix-socket 调 supervisor API（缺 Authorization 头 → 401）
#   Build #36: 加 nmcli 等待 + 重试
#   Build #37: 加 NM dispatcher 双保险
#   Build #38: 改用 ha CLI（内部已含 SUPERVISOR_TOKEN），避免 host 端拿 token
#              增加 hassio_cli 容器 exec 兜底
#
# 可被 systemd service 调用，也可被 NetworkManager dispatcher 调用

set -e

SUPERVISOR_SOCK="/var/run/supervisor.sock"
DNS_SERVERS="223.5.5.5 119.29.29.29"
DNS_COREDNS_JSON="/mnt/data/supervisor/dns/coredns.json"

log() {
    echo "[hassos-dns-cn-init] $1"
    logger -t hassos-dns-cn-init "$1" 2>/dev/null || true
}

# 配置 host DNS (systemd-resolved + NetworkManager)
# 关键：hassio_dns 的 locals 会从 host DNS 读取；host DNS 快则容器 DNS 也快
configure_host_dns() {
    log "配置 host DNS ..."
    local dns_servers="223.5.5.5 119.29.29.29"

    # 方法1: 使用 resolvectl 设置 per-interface DNS（立即生效）
    if command -v resolvectl >/dev/null 2>&1; then
        if resolvectl dns end0 $dns_servers 2>/dev/null; then
            log "resolvectl 设置 end0 DNS 成功"
        else
            log "WARNING: resolvectl 设置 end0 DNS 失败"
        fi
    fi

    # 方法2: 使用 nmcli 修改当前连接（持久化）
    if command -v nmcli >/dev/null 2>&1; then
        local conn_name=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | grep ':end0$' | cut -d: -f1 | head -1)
        if [ -n "$conn_name" ]; then
            if nmcli connection modify "$conn_name" ipv4.dns "$dns_servers" ipv4.ignore-auto-dns yes 2>/dev/null; then
                log "nmcli 修改连接 $conn_name IPv4 DNS 成功"
            else
                log "WARNING: nmcli 修改连接 $conn_name IPv4 DNS 失败"
            fi
            if nmcli connection modify "$conn_name" ipv6.ignore-auto-dns yes 2>/dev/null; then
                log "nmcli 禁用 $conn_name IPv6 auto DNS 成功"
            else
                log "WARNING: nmcli 禁用 $conn_name IPv6 auto DNS 失败"
            fi
        else
            log "WARNING: 未找到 end0 的活动连接"
        fi
    fi
}

# 检查 supervisor.sock 是否就绪
wait_for_supervisor_sock() {
    log "等待 supervisor.sock 就绪 ..."
    for i in $(seq 1 180); do
        [ -S "$SUPERVISOR_SOCK" ] && break
        sleep 1
    done
    if [ ! -S "$SUPERVISOR_SOCK" ]; then
        log "ERROR: supervisor.sock 180s 内未就绪"
        return 1
    fi
    return 0
}

# 检查 hassio_cli 容器是否启动（ha CLI 入口）
wait_for_hassio_cli() {
    log "等待 hassio_cli 容器就绪 ..."
    for i in $(seq 1 180); do
        if command -v docker >/dev/null 2>&1; then
            if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
                return 0
            fi
        fi
        sleep 1
    done
    log "WARNING: hassio_cli 容器 180s 内未就绪"
    return 1
}

# 检查 end0 是否已获取 IPv4
wait_for_ipv4() {
    log "等待 end0 获取 IPv4 ..."
    for i in $(seq 1 180); do
        if command -v nmcli >/dev/null 2>&1; then
            if nmcli -g IP4.ADDRESS device show end0 2>/dev/null | grep -Eq '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'; then
                log "end0 IPv4 已获取"
                return 0
            fi
        else
            if ip -4 addr show end0 2>/dev/null | grep -Eq 'inet [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/'; then
                log "end0 IPv4 已获取 (ip command)"
                return 0
            fi
        fi
        sleep 1
    done
    log "WARNING: 180s 内未检测到 end0 IPv4，继续尝试配置 ..."
    return 1
}

# 幂等检查：通过 hassio_cli 容器调 ha dns info
is_already_configured() {
    if command -v docker >/dev/null 2>&1; then
        INFO=$(docker exec hassio_cli ha dns info 2>/dev/null || true)
        if echo "$INFO" | grep -q "223.5.5.5"; then
            log "国内 DNS 已配置 (hassio_cli ha dns info)，跳过"
            return 0
        fi
    fi
    if [ -f "$DNS_COREDNS_JSON" ] && command -v jq >/dev/null 2>&1; then
        if jq -e '.servers | index("dns://223.5.5.5")' "$DNS_COREDNS_JSON" >/dev/null 2>&1; then
            log "国内 DNS 已配置 (coredns.json)，跳过"
            return 0
        fi
    fi
    return 1
}

# 修复 CoreDNS JSON 中的 Cloudflare DoT fallback
# Cloudflare DoT (1.1.1.1:853, 1.0.0.1:853) 在国内被封，导致 CoreDNS .:5553 端口超时
# supervisor 的 CoreDNS 模板始终包含 Cloudflare DoT forward 作为 5553 端口上游，
# ha dns options 只改端口 53 的 forward，不动端口 5553
# 需要直接修改生成的 coredns.json，替换所有 Cloudflare 端点为国内 DNS
fix_coredns_dot_fallback() {
    local coredns_json="/mnt/data/supervisor/dns/coredns.json"
    if [ ! -f "$coredns_json" ]; then
        log "coredns.json 不存在，跳过 DoT 修复"
        return 1
    fi

    # 检查是否包含 Cloudflare DoT 端点
    if ! grep -qE '1\.1\.1\.1|1\.0\.0\.1|cloudflare' "$coredns_json" 2>/dev/null; then
        log "coredns.json 不含 Cloudflare 端点，无需替换 DoT"
        return 0
    fi

    log "检测到 Cloudflare DoT fallback，替换为国内 DNS（223.5.5.5 / 119.29.29.29）..."

    # 备份
    cp "$coredns_json" "${coredns_json}.bak" 2>/dev/null || true

    # 替换 tls://1.1.1.1 → dns://223.5.5.5
    # 替换 tls://1.0.0.1 → dns://119.29.29.29
    # 这是关键：CoreDNS .:5553 用 Cloudflare DoT 作上游，国内被封
    sed -i \
        -e 's|tls://1\.1\.1\.1|dns://223.5.5.5|g' \
        -e 's|tls://1\.0\.0\.1|dns://119.29.29.29|g' \
        -e 's|tls://1\.1\.1\.2|dns://223.5.5.5|g' \
        -e 's|tls://1\.0\.0\.2|dns://119.29.29.29|g' \
        -e 's|tls://cloudflare-dns\.com|dns://223.5.5.5|g' \
        "$coredns_json" 2>/dev/null || {
            log "WARNING: sed 替换 DoT 失败，恢复备份"
            mv "${coredns_json}.bak" "$coredns_json" 2>/dev/null || true
            return 1
        }

    log "Cloudflare DoT 已替换为国内 DNS"
    return 0
}

# 方案 A：通过 ha CLI 配置 DNS（推荐，CLI 内部已处理 token）
configure_via_ha_cli() {
    log "通过 'ha dns' CLI 配置国内 DNS ..."
    if ! command -v docker >/dev/null 2>&1; then
        log "docker 命令不可用"
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
        log "hassio_cli 容器未运行"
        return 1
    fi

    # 先禁用 fallback
    if docker exec hassio_cli ha dns options --fallback=false 2>&1; then
        log "fallback=false 设置成功"
    else
        log "WARNING: 禁用 fallback 失败"
    fi

    # 设置国内 DNS servers
    local opts=""
    for s in $DNS_SERVERS; do
        opts="$opts --servers dns://$s"
    done
    if docker exec hassio_cli ha dns options $opts 2>&1; then
        log "国内 DNS servers 设置成功"
    else
        log "WARNING: 设置 DNS servers 失败"
        return 1
    fi

    # 关键：先配置 host DNS，再重启 hassio_dns
    # 这样 hassio_dns 重启时会读取新 locals (223.5.5.5/119.29.29.29)，而非路由器慢 DNS
    # 注意：若 host DNS 配置失败，hassio_dns 重启后 locals 仍为 192.168.1.1 → 修复无效
    configure_host_dns

    # 重启 hassio_dns（带重试，避免 "Another job is running"）
    local restart_ok=0
    for i in $(seq 1 10); do
        if docker exec hassio_cli ha dns restart 2>&1; then
            log "hassio_dns 重启成功"
            restart_ok=1
            break
        fi
        log "WARNING: hassio_dns 重启失败，5s 后重试 ($i/10) ..."
        sleep 5
    done
    if [ "$restart_ok" -ne 1 ]; then
        log "WARNING: hassio_dns 经过 10 次重试仍无法重启"
    fi

    # 修复 Cloudflare DoT fallback（国内封 Cloudflare DoT，导致 checkonline 超时）
    # 必须放在 ha dns restart 之后：restart 会重新生成 coredns.json（此时仍有 Cloudflare），
    # 然后我们直接修改 JSON 替换 Cloudflare 为国内 DNS。
    # 注意：不能再用 ha dns restart，因为 supervisor 会从模板重新生成 JSON，覆盖我们的修复！
    # 必须用 docker restart hassio_dns（只重启容器，读取已修改的文件，不触发重新生成）
    if fix_coredns_dot_fallback; then
        log "重新加载 hassio_dns 使 DoT 修复生效（docker restart，非 ha dns restart）..."
        docker restart hassio_dns 2>/dev/null && {
            log "hassio_dns 容器重启成功，DoT 修复已生效"
            sleep 3  # 等待 CoreDNS 启动
        } || log "WARNING: docker restart hassio_dns 失败"
    fi

    # 关键：触发 supervisor 重新检测网络 + 拉 HA Core 镜像
    # supervisor 启动时 DNS 未修好，被标记 'No Supervisor connectivity'，
    # 永远不会下载 ghcr.io 上的 homeassistant 镜像 (8123 永远是 landingpage)
    log "触发 supervisor 重新检测网络 (ha resolution healthcheck + ha supervisor reload) ..."
    docker exec hassio_cli ha resolution healthcheck 2>&1 || log "WARNING: healthcheck 失败"
    docker exec hassio_cli ha supervisor reload 2>&1 || log "WARNING: supervisor reload 失败"
    sleep 3
    # 再触发一次 healthcheck
    docker exec hassio_cli ha resolution healthcheck 2>&1 || log "WARNING: 第二次 healthcheck 失败"
    return 0
}

# 方案 B：通过 hassio_cli 容器 curl supervisor API（带 token）
configure_via_hassio_cli_curl() {
    log "通过 hassio_cli 容器 curl supervisor API ..."
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
        return 1
    fi

    # 在 hassio_cli 容器内执行 curl，自动获取 SUPERVISOR_TOKEN 环境变量
    local body='{"servers":["dns://223.5.5.5","dns://119.29.29.29"],"fallback":false}'
    if docker exec -e BODY="$body" hassio_cli sh -c 'curl -fsS -m 30 -X POST -H "Authorization: Bearer $SUPERVISOR_TOKEN" -H "Content-Type: application/json" -d "$BODY" http://supervisor/dns/options' 2>&1; then
        log "Supervisor API 配置成功"
        docker exec hassio_cli curl -fsS -m 30 -X POST -H "Authorization: Bearer $SUPERVISOR_TOKEN" http://supervisor/dns/restart 2>&1 || true
        return 0
    fi
    return 1
}

# 方案 C：直接修改 coredns.json + 写信号文件通知 supervisor
configure_via_coredns_json() {
    log "兜底方案：直接修改 $DNS_COREDNS_JSON ..."
    if [ ! -d "$(dirname "$DNS_COREDNS_JSON")" ]; then
        mkdir -p "$(dirname "$DNS_COREDNS_JSON")"
    fi

    if [ -f "$DNS_COREDNS_JSON" ] && command -v jq >/dev/null 2>&1; then
        # 保留其他字段，仅修改 servers 和 fallback
        jq '.servers = ["dns://223.5.5.5", "dns://119.29.29.29"] | .fallback = false' "$DNS_COREDNS_JSON" > "${DNS_COREDNS_JSON}.tmp" \
            && mv "${DNS_COREDNS_JSON}.tmp" "$DNS_COREDNS_JSON"
    else
        printf '%s\n' '{"servers":["dns://223.5.5.5","dns://119.29.29.29"],"fallback":false,"version":"2026.07.11"}' > "$DNS_COREDNS_JSON"
    fi

    log "coredns.json 已更新: $(cat $DNS_COREDNS_JSON 2>/dev/null)"

    # 尝试通过 hassio_cli 重启 hassio_dns
    if command -v docker >/dev/null 2>&1; then
        if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
            docker exec hassio_cli ha dns restart 2>&1 || log "WARNING: 重启 hassio_dns 失败"
        fi
    fi
    return 0
}

# 主流程
main() {
    log "启动 (hassos-dns-cn-init)"

    # dispatcher 调用时带 interface 参数
    if [ -n "$1" ] && [ "$1" != "end0" ] && [ "$1" != "--force" ]; then
        log "非 end0 接口 ($1)，跳过"
        exit 0
    fi

    # 先配置 host DNS（无需等待 supervisor），让系统 / dockerd 尽早使用国内 DNS
    configure_host_dns

    wait_for_supervisor_sock || true
    wait_for_ipv4 || true
    wait_for_hassio_cli || true

    if is_already_configured; then
        log "国内 DNS 已配置，但仍需修复 Cloudflare DoT fallback 并重启 ..."
        # 不跳过：即使 servers 正确，Cloudflare DoT 仍可能阻塞连通性检查
    fi

    # 方案 A: ha CLI
    if configure_via_ha_cli; then
        log "完成 (via 'ha dns' CLI)"
        # 验证最终状态
        sleep 2
        if command -v docker >/dev/null 2>&1; then
            docker exec hassio_cli ha dns info 2>&1 | head -10 | while read line; do
                log "  ha dns info: $line"
            done
        fi
        exit 0
    fi

    # 方案 B: hassio_cli curl
    if configure_via_hassio_cli_curl; then
        log "完成 (via hassio_cli curl)"
        exit 0
    fi

    # 方案 C: coredns.json 兜底
    log "WARNING: 所有 API 方案失败，兜底写 coredns.json"
    configure_via_coredns_json
    log "完成 (via coredns.json fallback)"
    log "用户可手动执行: ha dns options --fallback=false --servers dns://223.5.5.5 --servers dns://119.29.29.29"
}

main "$@"
