#!/bin/sh
# HAOS-CN: 强制 supervisor 重新检测网络连接
# 解决 supervisor 启动时 DNS 未修好导致永久 'No Supervisor connectivity' 的问题

set -e

# 修复 CoreDNS JSON 中的 Cloudflare DoT fallback
fix_coredns_dot_fallback() {
    local coredns_json="/mnt/data/supervisor/dns/coredns.json"
    if [ ! -f "$coredns_json" ]; then
        return 1
    fi
    if ! grep -qE '1\.1\.1\.1|1\.0\.0\.1' "$coredns_json" 2>/dev/null; then
        return 0
    fi
    cp "$coredns_json" "${coredns_json}.bak" 2>/dev/null || true
    sed -i \
        -e 's|tls://1\.1\.1\.1|dns://223.5.5.5|g' \
        -e 's|tls://1\.0\.0\.1|dns://119.29.29.29|g' \
        -e 's|tls://1\.1\.1\.2|dns://223.5.5.5|g' \
        -e 's|tls://1\.0\.0\.2|dns://119.29.29.29|g' \
        "$coredns_json" 2>/dev/null || { mv "${coredns_json}.bak" "$coredns_json" 2>/dev/null; return 1; }
    return 0
}

log() {
    echo "[hassos-dns-cn-init-recheck] $1"
    logger -t hassos-dns-cn-init-recheck "$1" 2>/dev/null || true
}

# 配置 host DNS，确保 hassio_dns 的 locals 不是路由器慢 DNS
# 关键修复 (Build #43): 加重试循环，因为 timer 触发时可能 NM 还没激活 end0
configure_host_dns() {
    local dns_servers="223.5.5.5 119.29.29.29"
    if command -v resolvectl >/dev/null 2>&1; then
        resolvectl dns end0 $dns_servers 2>/dev/null || true
    fi
    if command -v nmcli >/dev/null 2>&1; then
        local conn_name=""
        local attempt=0
        local max_attempts=10
        while [ $attempt -lt $max_attempts ]; do
            conn_name=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | grep ':end0$' | cut -d: -f1 | head -1)
            if [ -n "$conn_name" ]; then
                break
            fi
            attempt=$((attempt + 1))
            sleep 2
        done
        if [ -n "$conn_name" ]; then
            nmcli connection modify "$conn_name" ipv4.dns "$dns_servers" ipv4.ignore-auto-dns yes 2>/dev/null || true
            nmcli connection modify "$conn_name" ipv6.ignore-auto-dns yes 2>/dev/null || true
        fi
    fi
}

# 等待 hassio_dns 健康（CoreDNS listening on .:53）
# 关键修复 (Build #43): 避免在 hassio_dns 起来前 healthcheck 导致
# dockerd [resolver] 解析超时 → supervisor 立即判 No connectivity
wait_for_hassio_dns_healthy() {
    local attempt=0
    local max_attempts=60
    while [ $attempt -lt $max_attempts ]; do
        if command -v docker >/dev/null 2>&1; then
            if docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
                if (echo > /dev/tcp/127.0.0.1/53) 2>/dev/null; then
                    return 0
                fi
            fi
        fi
        attempt=$((attempt + 1))
        if [ $((attempt % 10)) -eq 0 ]; then
            log "hassio_dns 尚未健康 (尝试 $attempt/$max_attempts) ..."
        fi
        sleep 1
    done
    return 1
}

# 等待 hassio_cli 容器就绪
for i in $(seq 1 60); do
    if command -v docker >/dev/null 2>&1; then
        if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
            break
        fi
    fi
    sleep 1
done

if ! command -v docker >/dev/null 2>&1; then
    log "docker 命令不可用"
    exit 0
fi
if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
    log "hassio_cli 容器未就绪"
    exit 0
fi

configure_host_dns

# 检查当前 supervisor 是否认为已联网
CONNECTED=$(docker exec hassio_cli ha resolution info 2>/dev/null | grep -i "connected" | head -1 || true)
if echo "$CONNECTED" | grep -qi "true"; then
    log "supervisor 已联网 ($CONNECTED)，停止重试"
    # 停掉本 timer
    systemctl stop hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    systemctl disable hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    exit 0
fi

log "supervisor 仍未联网，修复 Cloudflare DoT fallback + 触发 healthcheck + reload ..."

# 修复 CoreDNS DoT fallback 并重启
configure_host_dns
if fix_coredns_dot_fallback; then
    log "Cloudflare DoT 已替换，重启 hassio_dns 容器使修复生效（docker restart，非 ha dns restart）..."
    docker restart hassio_dns 2>/dev/null && sleep 3 || true
fi
# 关键修复 (Build #43): 等 hassio_dns 健康再 healthcheck
wait_for_hassio_dns_healthy || true
# 关键修复 (Build #44): 重启 dockerd + assismgr 让它们重读 /etc/resolv.conf
# dockerd 启动时缓存的 dhcp 路由器 DNS (192.168.1.1) 不会动态更新，
# 导致 dockerd [resolver] 仍发到 192.168.1.1:53 (国内慢)。
if command -v systemctl >/dev/null 2>&1; then
    log "重启 dockerd 让其重读 /etc/resolv.conf (hassio_dns 已就绪) ..."
    systemctl restart docker 2>&1 | head -3 || true
    sleep 8
    log "重启 assismgr 让其重读 /etc/resolv.conf ..."
    systemctl restart assismgr 2>&1 | head -3 || true
fi
docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
docker exec hassio_cli ha supervisor reload 2>&1 | head -5 || true
sleep 3
docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
log "完成（下一次 timer 触发时会再次重试）"
exit 0
