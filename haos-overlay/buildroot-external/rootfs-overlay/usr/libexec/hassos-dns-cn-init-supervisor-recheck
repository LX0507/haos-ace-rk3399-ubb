#!/bin/sh
# HAOS-CN: 强制 supervisor 重新检测网络连接
# 解决 supervisor 启动时 DNS 未修好导致永久 'No Supervisor connectivity' 的问题

set -e

log() {
    echo "[hassos-dns-cn-init-recheck] $1"
    logger -t hassos-dns-cn-init-recheck "$1" 2>/dev/null || true
}

# 配置 host DNS，确保 hassio_dns 的 locals 不是路由器慢 DNS
configure_host_dns() {
    local dns_servers="223.5.5.5 119.29.29.29"
    if command -v resolvectl >/dev/null 2>&1; then
        resolvectl dns end0 $dns_servers 2>/dev/null || true
    fi
    if command -v nmcli >/dev/null 2>&1; then
        local conn_name=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | grep ':end0$' | cut -d: -f1 | head -1)
        if [ -n "$conn_name" ]; then
            nmcli connection modify "$conn_name" ipv4.dns "$dns_servers" ipv4.ignore-auto-dns yes 2>/dev/null || true
            nmcli connection modify "$conn_name" ipv6.ignore-auto-dns yes 2>/dev/null || true
        fi
    fi
}

# 等待 hassio_cli 容器就绪
for i in $(seq 1 60); do
    if command -v docker >/dev/null 2>&1; then
        if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
            break
        fi
    fi
    sleep 1
done

if ! command -v docker >/dev/null 2>&1; then
    log "docker 命令不可用"
    exit 0
fi
if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
    log "hassio_cli 容器未就绪"
    exit 0
fi

configure_host_dns

# 检查当前 supervisor 是否认为已联网
CONNECTED=$(docker exec hassio_cli ha resolution info 2>/dev/null | grep -i "connected" | head -1 || true)
if echo "$CONNECTED" | grep -qi "true"; then
    log "supervisor 已联网 ($CONNECTED)，停止重试"
    # 停掉本 timer
    systemctl stop hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    systemctl disable hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    exit 0
fi

log "supervisor 仍未联网，触发 healthcheck + reload ..."
docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
docker exec hassio_cli ha supervisor reload 2>&1 | head -5 || true
sleep 3
docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
log "完成（下一次 timer 触发时会再次重试）"
exit 0
