#!/bin/sh
# HAOS-CN: 强制 supervisor 重新检测网络连接
# 解决 supervisor 启动时 DNS 未修好导致永久 'No Supervisor connectivity' 的问题
#
# Build #45: 关键根因修复 - 直接修改 hassio_dns 容器内 /etc/corefile 中的
#            Cloudflare DoT 硬编码 (1.1.1.1/1.0.0.1)，用 SIGHUP 让 coredns 重读
#            + flock 防止并发执行

set -e

# Build #50: 与 hassos-dns-cn-init 共用同一把锁, 避免二者并发执行 ha dns / 改 Corefile
LOCK_FILE="/var/run/hassos-dns-cn-init.lock"
# Build #51: 只用全局固定的公共 DNS, 彻底移除网关检测 (网关进 forward 会 loop FATAL)
DNS_SERVERS=""

log() {
    echo "[hassos-dns-cn-init-recheck] $1"
    logger -t hassos-dns-cn-init-recheck "$1" 2>/dev/null || true
}

# 公共 DNS 上游 (国内可达, 全局固定 IP, 与家庭网段无关) - 同 hassos-dns-cn-init
PUBLIC_DNS_LIST="119.29.29.29 223.5.5.5 8.8.8.8"

# 生成 CoreDNS forward 用的上游列表 (dns:// 前缀, 空格分隔, 公共 DNS, 不含网关)
build_upstream_fmt() {
    local out=""
    for s in $PUBLIC_DNS_LIST; do
        out="$out dns://$s"
    done
    echo "${out# }"
}

# 检查 hassio_dns 容器内 /etc/corefile 是否已修复
#   - .:5553 不含 CloudFlare DoT
#   - .:53 不含网关/私有 IP (loop 风险)
is_corefile_already_fixed() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
        return 1
    fi
    if docker exec hassio_dns sh -c 'grep -qE "tls://1\.1\.1\.1|tls://1\.0\.0\.1|tls://cloudflare-dns\.com" /etc/corefile' 2>/dev/null; then
        return 1
    fi
    if docker exec hassio_dns sh -c 'grep -qE "forward \. dns://(192\.168|10\.|172\.(1[0-9]|2[0-9]|3[01]))\." /etc/corefile' 2>/dev/null; then
        return 1
    fi
    return 0
}

# 修复 hassio_dns 容器内 /etc/corefile (Build #51 重新设计)
# 只做两件事, 绝不把网关 IP 放进 '.:53' forward (那会触发 plugin/loop FATAL):
#   1. '.:5553' CloudFlare DoT -> 公共 DNS 列表
#   2. '.:53' 若被旧脚本写成网关/私有 IP -> 还原为 dns://127.0.0.11 (stock)
fix_coredns_dot_fallback() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
        log "hassio_dns 容器未运行，跳过 Corefile 修复"
        return 1
    fi

    local UPSTREAM_FMT=$(build_upstream_fmt)
    log "Corefile 公共 DNS 上游: $UPSTREAM_FMT"

    if is_corefile_already_fixed; then
        log "hassio_dns 容器 /etc/corefile 已修复，跳过"
        return 0
    fi

    log "检测到 hassio_dns 容器 /etc/corefile 需要修复 ..."
    docker exec hassio_dns sh -c 'cp -f /etc/corefile /etc/corefile.bak 2>/dev/null || true' || true

    # (1) 仅替换 '.:5553' CloudFlare DoT 行为公共 DNS 列表 (tls:// 精确匹配 .:5553)
    if docker exec hassio_dns sh -c "sed -i -E 's|^( *)forward \. tls://.*|\1forward . ${UPSTREAM_FMT}|' /etc/corefile" 2>/dev/null; then
        log "已替换 .:5553 CloudFlare DoT 为公共 DNS: ${UPSTREAM_FMT}"
    else
        log "WARNING: 替换 .:5553 失败"
        return 1
    fi

    # (2) 若 .:53 被旧脚本写成网关/私有 IP, 还原为 dns://127.0.0.11 (stock, 绝不 loop)
    if docker exec hassio_dns sh -c "sed -i -E 's|^( *)forward \. dns://(192\.168|10\.|172\.(1[0-9]|2[0-9]|3[01]))\.[0-9]+\.[0-9]+.*|\1forward . dns://127.0.0.11|' /etc/corefile" 2>/dev/null; then
        log "已确保 .:53 forward 为 dns://127.0.0.11 (stock, 无 loop)"
    else
        log "WARNING: 还原 .:53 失败"
        return 1
    fi

    # 用 SIGHUP 让 CoreDNS 重新读取 Corefile
    if docker exec hassio_dns sh -c 'pkill -HUP coredns 2>/dev/null; sleep 1' 2>/dev/null; then
        log "已 SIGHUP hassio_dns 容器内 coredns 让其重读 Corefile"
        return 0
    fi
    if docker exec hassio_dns sh -c 's6-svc -h /run/service/coredns 2>/dev/null; sleep 1' 2>/dev/null; then
        log "已通过 s6-svc -h 重启 hassio_dns 容器内 coredns"
        return 0
    fi
    log "WARNING: 通知 CoreDNS 重读 Corefile 失败"
    return 1
}

# 配置 host DNS，指向 hassio_dns (由 Corefile 多上游故障转移处理解析)
configure_host_dns() {
    local dns_servers="172.30.32.3"
    if command -v resolvectl >/dev/null 2>&1; then
        resolvectl dns end0 $dns_servers 2>/dev/null || true
    fi
    if command -v nmcli >/dev/null 2>&1; then
        local conn_name=""
        local attempt=0
        local max_attempts=10
        while [ $attempt -lt $max_attempts ]; do
            conn_name=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | grep ':end0$' | cut -d: -f1 | head -1)
            if [ -n "$conn_name" ]; then
                break
            fi
            attempt=$((attempt + 1))
            sleep 2
        done
        if [ -n "$conn_name" ]; then
            nmcli connection modify "$conn_name" ipv4.dns "$dns_servers" ipv4.ignore-auto-dns yes 2>/dev/null || true
            nmcli connection modify "$conn_name" ipv6.ignore-auto-dns yes 2>/dev/null || true
        fi
    fi
}

# 等待 hassio_dns 健康（CoreDNS 进程在容器内运行）
# 关键修复 (Build #46): 之前检测 host 127.0.0.1:53，但 hassio_dns 容器**不监听 host
# 127.0.0.1:53**（只在 hassio bridge 172.30.32.3:53 监听）。改为在容器内用 docker exec 检测
wait_for_hassio_dns_healthy() {
    local attempt=0
    local max_attempts=60
    while [ $attempt -lt $max_attempts ]; do
        if command -v docker >/dev/null 2>&1; then
            if docker inspect --format '{{.State.Running}}' hassio_dns 2>/dev/null | grep -q true; then
                if docker exec hassio_dns sh -c 'pidof coredns >/dev/null 2>&1' 2>/dev/null; then
                    return 0
                fi
            fi
        fi
        attempt=$((attempt + 1))
        if [ $((attempt % 10)) -eq 0 ]; then
            log "hassio_dns 尚未健康 (尝试 $attempt/$max_attempts) ..."
        fi
        sleep 1
    done
    return 1
}

# 关键修复 (Build #45): 用 flock 防止 timer 触发时与 hassos-dns-cn-init 并发
if command -v flock >/dev/null 2>&1; then
    exec 9>"$LOCK_FILE"
    if ! flock -w 16 9; then
        log "另一个 hassos-dns-cn-init(-recheck) 实例正在执行，跳过"
        exit 0
    fi
fi

# Build #51: DNS 用公共 DNS (全局固定 IP, 与家庭网段无关), 不再运行时检测网关
DNS_SERVERS="119.29.29.29"
log "DNS 上游: 公共 DNS (119.29.29.29/223.5.5.5/8.8.8.8, 与家庭网段无关)"

# 等待 hassio_cli 容器就绪
for i in $(seq 1 60); do
    if command -v docker >/dev/null 2>&1; then
        if docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
            break
        fi
    fi
    sleep 1
done

if ! command -v docker >/dev/null 2>&1; then
    log "docker 命令不可用"
    exit 0
fi
if ! docker inspect --format '{{.State.Running}}' hassio_cli 2>/dev/null | grep -q true; then
    log "hassio_cli 容器未就绪"
    exit 0
fi

configure_host_dns

# 检查当前 supervisor 是否认为已联网
# 注意: 'connected' 字段在 `ha supervisor info` 中, 不在 `ha resolution info`
CONNECTED=$(docker exec hassio_cli ha supervisor info 2>/dev/null | grep -iE "^[[:space:]]*connected:" | head -1 || true)
if echo "$CONNECTED" | grep -qi "true"; then
    log "supervisor 已联网 ($CONNECTED)，停止重试"
    # 停掉本 timer
    systemctl stop hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    systemctl disable hassos-dns-cn-init-supervisor-recheck.timer 2>/dev/null || true
    exit 0
fi

log "supervisor 仍未联网，修复 Cloudflare DoT + 设置公共 DNS + 触发 healthcheck + reload ..."

# 关键修复 (Build #45): 修复 hassio_dns 容器内 /etc/corefile 的 Cloudflare DoT
configure_host_dns
fix_coredns_dot_fallback || true
wait_for_hassio_dns_healthy || true

# Build #51: 通过 ha dns options 把公共 DNS 写入 supervisor 配置,
# 使随后的 'ha supervisor reload' 重新生成 Corefile 时保持公共 DNS (而非回退 CloudFlare DoT)
docker exec hassio_cli ha dns options --fallback=false \
    --servers dns://119.29.29.29 --servers dns://223.5.5.5 --servers dns://8.8.8.8 2>&1 | head -5 || true

# 关键修复 (Build #44): 重启 assismgr 让其重读 /etc/resolv.conf
# Build #45: 不重启 dockerd（避免重启 supervisor 容器导致 hassio_dns 重新生成 Corefile）
if command -v systemctl >/dev/null 2>&1; then
    log "重启 assismgr 让其重读 /etc/resolv.conf ..."
    systemctl restart assismgr 2>&1 | head -3 || true
fi

docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
docker exec hassio_cli ha supervisor reload 2>&1 | head -5 || true
sleep 3
docker exec hassio_cli ha resolution healthcheck 2>&1 | head -5 || true
log "完成（下一次 timer 触发时会再次重试）"
exit 0
