#!/bin/sh
# haos-net-china — 在 supervisor 接管网络之前，把当前 end0 活动连接的 DNS
# 强制改为中国可达的公共 DNS 并 ignore-auto-dns，确保：
#   1) 主机 resolv.conf 使用公共 DNS（dockerd 拉取 ghcr.io 镜像可正常解析）；
#   2) supervisor 接管 "Supervisor end0" 时继承公共 DNS（而非路由器 192.168.1.1）；
#   3) plugin-dns(CoreDNS) 上游为公共 DNS，checkonline.home-assistant.io 可解析
#      → supervisor 获得连通性 → Home Assistant Core 镜像得以下载安装。
# 不写死任何网关/网段 IP，天然适配任意路由器。
set -u

PUB_DNS="119.29.29.29,223.5.5.5,114.114.114.114"
PUB_DNS6="2400:3200::1,2400:da00::6666"

# 取 end0 当前活动连接（supervisor 接管前通常是 "Wired connection 1"）
CONN=$(nmcli -g GENERAL.CONNECTION device show end0 2>/dev/null | head -n1)
if [ -z "$CONN" ]; then
    # 兜底：直接尝试默认连接名
    CONN="Wired connection 1"
fi

# 修改该连接：忽略路由器下发的 DNS，只使用公共 DNS
nmcli connection modify "$CONN" \
    ipv4.ignore-auto-dns yes \
    ipv4.dns "$PUB_DNS" \
    ipv4.dns-priority -1 \
    ipv6.ignore-auto-dns yes \
    ipv6.dns "$PUB_DNS6" \
    ipv6.dns-priority -1 2>/dev/null

# 重新激活使 DNS 立即生效
nmcli connection up "$CONN" 2>/dev/null

exit 0
